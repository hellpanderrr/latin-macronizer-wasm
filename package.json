{
  "name": "latin-macronizer-browser",
  "version": "1.0.0",
  "description": "Latin macronizer ported to browser JavaScript with WASM RFTagger support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node fix-imports.cjs && npm run copy-assets",
    "build:prod": "tsc --project tsconfig.prod.json && npm run copy-assets",
    "dev": "tsc --watch",
    "test": "jest",
    "test:parity": "node test/e2e/parity-node.mjs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "build:wasm": "bash native/build/emscripten-build.sh",
    "build:wasm:docker": "docker-compose -f native/build/docker-compose.yml up wasm-builder",
    "copy-assets": "node copy-assets.cjs"
  },
  "keywords": [
    "latin",
    "macronizer",
    "pos-tagging",
    "webassembly",
    "rftagger",
    "nlp",
    "linguistics"
  ],
  "author": "Latin Macronizer Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hellpanderrr/latin-macronizer-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/hellpanderrr/latin-macronizer-wasm/issues"
  },
  "homepage": "https://github.com/hellpanderrr/latin-macronizer-wasm#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    ">= 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not IE 11"
  ],
  "dependencies": {
    "wasm-feature-detect": "^1.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^8.40.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.5.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.0.0",
    "vite": "^8.0.10"
  },
  "files": [
    "dist/",
    "public/wasm/",
    "README.md",
    "LICENSE"
  ]
}
